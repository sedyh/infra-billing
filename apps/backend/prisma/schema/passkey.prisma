model Passkey {
  uuid String @id @default(uuid()) @map("uuid")

  // SimpleWebAuthn credential.id — a base64url STRING (not Bytes); used directly in allowCredentials.
  credentialId String  @unique @map("credential_id")
  publicKey    Bytes   @map("public_key")
  counter      BigInt  @default(0) @map("counter")
  transports   String? @map("transports")
  deviceType   String? @map("device_type")
  backedUp     Boolean @default(false) @map("backed_up")

  name       String?   @map("name")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("passkeys")
}
