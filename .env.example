PORT=8080

# AES-256-GCM key for secrets at rest (provider tokens, admin session secret); openssl rand -base64 32
ENCRYPTION_KEY=

# host = compose service infra-billing-db (local dev outside docker: 127.0.0.1)
DATABASE_URL="postgresql://infra:change-me-please@infra-billing-db:5432/infra_billing?schema=public"

# Postgres container only — not read by the app:
POSTGRES_USER=infra
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=infra_billing
POSTGRES_HOST_PORT=5432
